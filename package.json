{
  "name": "zephyr-sentinel",
  "version": "1.0.0",
  "description": "A website/API change monitoring and notification system designed for GitHub Actions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "zephyr-sentinel": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "monitor",
    "change-detection",
    "notification",
    "github-actions",
    "webhook"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "crypto-js": "^4.2.0",
    "diff": "^7.0.0",
    "js-yaml": "^4.1.0",
    "jsonpath-plus": "^10.3.0",
    "p-limit": "^6.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/crypto-js": "^4.2.2",
    "@types/diff": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}